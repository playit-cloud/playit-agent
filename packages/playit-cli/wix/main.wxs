<!--
  The "cargo wix" subcommand provides a variety of predefined variables available
  for customization of this template. The values for each variable are set at
  installer creation time. The following variables are available:

  TargetTriple      = The rustc target triple name.
  TargetEnv         = The rustc target environment. This is typically either
                      "msvc" or "gnu" depending on the toolchain downloaded and
                      installed.
  TargetVendor      = The rustc target vendor. This is typically "pc", but Rust
                      does support other vendors, like "uwp".
  CargoTargetBinDir = The complete path to the binary (exe). The default would
                      be "target\release\<BINARY_NAME>.exe" where
                      "<BINARY_NAME>" is replaced with the name of each binary
                      target defined in the package's manifest (Cargo.toml). If
                      a different rustc target triple is used than the host,
                      i.e. cross-compiling, then the default path would be
                      "target\<CARGO_TARGET>\<CARGO_PROFILE>\<BINARY_NAME>.exe",
                      where "<CARGO_TARGET>" is replaced with the "CargoTarget"
                      variable value and "<CARGO_PROFILE>" is replaced with the
                      value from the `CargoProfile` variable.
  CargoTargetDir    = The path to the directory for the build artifacts, i.e.
                      "target".
  CargoProfile      = Either "debug" or `release` depending on the build
                      profile. The default is "release".
  Version           = The version for the installer. The default is the
                      "Major.Minor.Fix" semantic versioning number of the Rust
                      package.
-->

<!--
  Please do not remove these pre-processor If-Else blocks. These are used with
  the `cargo wix` subcommand to automatically determine the installation
  destination for 32-bit versus 64-bit installers. Removal of these lines will
  cause installation errors.
-->
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">
    <Product
        Id="*"
        Name="playit"
        UpgradeCode="2640FEA4-3120-4DB0-93A9-6B04A4EFE7D2"
        Manufacturer="Developed Methods LLC"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package Id="*"
            Keywords="Installer"
            Manufacturer="Developed Methods LLC"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252"
            />

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            AllowSameVersionUpgrades="yes"
            AllowDowngrades="no"
            DowngradeErrorMessage="A newer version of [ProductName] is already installed. Setup will now exit."/>

        <Property Id="MSIRESTARTMANAGERCONTROL" Value="Disable" />
        <Property Id="PLAYITD_CLOSE_APPROVED" Value="0" />

        <util:CloseApplication
            Id="ClosePlayitService"
            Target="playitd.exe"
            Description="The Playit service is currently running and setup must stop it before continuing."
            RebootPrompt="no"
            Property="PLAYITD_SERVICE_RUNNING"
            Sequence="1" />

        <util:CloseApplication
            Id="ClosePlayitTray"
            Target="playitd-tray.exe"
            Description="The Playit tray application must be closed before setup can continue."
            CloseMessage="yes"
            EndSessionMessage="yes"
            RebootPrompt="no"
            Property="PLAYITD_TRAY_RUNNING"
            TerminateProcess="0"
            Sequence="2"
            Timeout="10" />

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1"/>
        <Property Id="DiskPrompt" Value="Playit Installation"/>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="LocalAppDataFolder">
                <Directory Id="MyAppDirectory" Name="playit_gg">
                    <Component Id="PlayitLocalAppDataFolder">
                        <CreateFolder />
                        <RemoveFolder Id="RemovePlayitLocalAppDataFolder" On="uninstall" />
                        <RegistryValue Root="HKCU" Key="Software\DevelopedMethodsLLC\playit_gg" Name="AppDataPath" Type="integer" Value="1" KeyPath="yes"/>
                    </Component>
                </Directory>
            </Directory>

            <Directory Id="CommonAppDataFolder">
                <Directory Id="PlayitCommonDataDirectory" Name="playit_gg">
                    <Component Id="PlayitCommonDataFolder" Guid="*">
                        <CreateFolder />
                        <RegistryValue Root="HKLM" Key="Software\DevelopedMethodsLLC\playit_gg" Name="CommonDataPath" Type="integer" Value="1" KeyPath="yes"/>
                    </Component>

                    <Directory Id="PlayitCommonDataLogsDirectory" Name="logs">
                        <Component Id="PlayitCommonDataLogsFolder" Guid="*">
                            <CreateFolder />
                            <RegistryValue Root="HKLM" Key="Software\DevelopedMethodsLLC\playit_gg" Name="CommonLogPath" Type="integer" Value="1" KeyPath="yes"/>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="Playit.gg">
                    <Component Id="ApplicationShortcut">
                        <Shortcut Id="ApplicationStartMenuShortcut"
                                  Name="Playit.gg"
                                  Description="Makes local ports public. Put your game servers online."
                                  Icon="ProductICO"
                                  Target="[APPLICATIONFOLDER]bin\playit.exe"
                        />
                        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall"/>
                        <RegistryValue Root="HKCU" Key="Software\DevelopedMethodsLLC\playit_gg" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
                    </Component>
                </Directory>
            </Directory>

            <Directory Id="$(var.PlatformProgramFilesFolder)" Name="PFiles">
                <Directory Id="APPLICATIONFOLDER" Name="playit_gg">
                    <!--
                    <Component Id="License" Guid="*">
                        <File Id="LicenseFile" Name="ChangeMe" DiskId="1" Source="C:\Path\To\File" KeyPath="yes"/>
                    </Component>
                    -->

                    <Directory Id="Bin" Name="bin">
                        <Component Id="Path" Guid="4472FB0A-A399-4967-99BD-E330FB737CE4" KeyPath="yes">
                            <Environment
                                Id="PATH"
                                Name="PATH"
                                Value="[Bin]"
                                Permanent="no"
                                Part="last"
                                Action="set"
                                System="yes"/>
                        </Component>
                        <Component Id="binary0" Guid="*">
                            <File
                                Id="exe0"
                                Name="playit.exe"
                                DiskId="1"
                                Source="$(var.CargoTargetBinDir)\playit-cli.exe"
                                KeyPath="yes"/>
                        </Component>
                        <Component Id="binary1" Guid="*">
                            <File
                                Id="exe1"
                                Name="playitd.exe"
                                DiskId="1"
                                Source="$(var.CargoTargetDir)\$(var.TargetTriple)\$(var.CargoProfile)\playitd.exe"
                                KeyPath="yes"/>
                        </Component>
                        <Component Id="binary2" Guid="*">
                            <File
                                Id="exe2"
                                Name="playitd-tray.exe"
                                DiskId="1"
                                Source="$(var.CargoTargetDir)\$(var.TargetTriple)\$(var.CargoProfile)\playitd-tray.exe"
                                KeyPath="yes"/>
                        </Component>
                        <Component Id="playitdServiceComponent" Guid="*">
                            <File
                                Id="playitdServiceExe"
                                Name="playitd-service.exe"
                                DiskId="1"
                                Source="$(var.CargoTargetDir)\$(var.TargetTriple)\$(var.CargoProfile)\playitd-service.exe"
                                KeyPath="yes"/>
                            <ServiceInstall
                                Id="playitdServiceInstall"
                                Name="playitd"
                                DisplayName="playitd"
                                Description="Runs the playitd background daemon for CLI IPC access."
                                Type="ownProcess"
                                Start="demand"
                                ErrorControl="normal"
                                Vital="yes"
                                Account="LocalSystem">
                                <util:PermissionEx
                                    User="Authenticated Users"
                                    ServiceStart="yes"
                                    ServiceStop="yes"
                                    ServiceQueryStatus="yes"
                                    ServiceInterrogate="yes" />
                            </ServiceInstall>
                            <ServiceControl
                                Id="playitdServiceControl"
                                Name="playitd"
                                Stop="both"
                                Remove="uninstall"
                                Wait="yes" />
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <Directory Id="DesktopFolder" Name="Desktop">
                <Component Id="ApplicationShortcutDesktop" Guid="6382d8dc-b9b0-4578-92b9-bad1cb41b9d8">
                    <Shortcut Id="ApplicationDesktopShortcut"
                        Name="Playit.gg"
                        Description="Makes local ports public. Put your game servers online."
                        Icon="ProductICO"
                        Target="[APPLICATIONFOLDER]bin\playit.exe"
                    />
                    <RegistryValue Root="HKCU" Key="Software\DevelopedMethodsLLC\playit_gg" Name="ShortcutAdded" Type="integer" Value="1" KeyPath="yes" />
                </Component>
            </Directory>

        </Directory>

        <Feature
            Id="Binaries"
            Title="Application"
            Description="Installs all binaries and the license."
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER"
            AllowAdvertise="no"
            Display="expand"
            Absent="disallow">

            <ComponentRef Id="binary0"/>
            <ComponentRef Id="binary1"/>
            <ComponentRef Id="binary2"/>
            <ComponentRef Id="playitdServiceComponent"/>
            <ComponentRef Id="PlayitLocalAppDataFolder"/>
            <ComponentRef Id="PlayitCommonDataFolder"/>
            <ComponentRef Id="PlayitCommonDataLogsFolder"/>
            <ComponentRef Id="ApplicationShortcut"/>
            <ComponentRef Id="ApplicationShortcutDesktop"/>
            <Feature
                Id="Environment"
                Title="PATH Environment Variable"
                Description="Add the install location of the [ProductName] executable to the PATH system environment variable. This allows the [ProductName] executable to be called from any location."
                Level="1"
                Absent="allow">
                <ComponentRef Id="Path"/>
            </Feature>
        </Feature>

        <SetProperty Id="ARPINSTALLLOCATION" Value="[APPLICATIONFOLDER]" After="CostFinalize"/>
        <Property Id="WixShellExecTarget" Value="[#exe2]" />
        <CustomAction Id="DetectRunningPlayit" Script="vbscript" Execute="immediate"><![CDATA[
Function IsServiceRunning(serviceName)
    Dim service, services, wmi

    IsServiceRunning = False
    Set wmi = GetObject("winmgmts:\\.\root\cimv2")
    Set services = wmi.ExecQuery("SELECT State FROM Win32_Service WHERE Name='" & serviceName & "'")

    For Each service In services
        If LCase(service.State) = "running" Then
            IsServiceRunning = True
        End If
        Exit Function
    Next
End Function

Function IsProcessRunning(processName)
    Dim process, processes, wmi

    IsProcessRunning = False
    Set wmi = GetObject("winmgmts:\\.\root\cimv2")
    Set processes = wmi.ExecQuery("SELECT Name FROM Win32_Process WHERE Name='" & processName & "'")

    For Each process In processes
        IsProcessRunning = True
        Exit Function
    Next
End Function

Session.Property("PLAYITD_SERVICE_RUNNING") = ""
Session.Property("PLAYITD_TRAY_RUNNING") = ""

If IsServiceRunning("playitd") Then
    Session.Property("PLAYITD_SERVICE_RUNNING") = "1"
End If

If IsProcessRunning("playitd-tray.exe") Then
    Session.Property("PLAYITD_TRAY_RUNNING") = "1"
End If
        ]]></CustomAction>
        <CustomAction
            Id="SetPlayitCloseApprovedSilently"
            Property="PLAYITD_CLOSE_APPROVED"
            Value="1"
            Execute="immediate" />
        <CustomAction
            Id="LaunchTrayApplication"
            BinaryKey="WixCA"
            DllEntry="WixShellExec"
            Impersonate="yes"
            Return="check" />
        <CustomAction
            Id="SetStopPlayitdServiceCommand"
            Property="WixQuietExecCmdLine"
            Value="&quot;[SystemFolder]cmd.exe&quot; /c net stop playitd /y"
            Execute="immediate" />
        <CustomAction
            Id="StopPlayitdService"
            BinaryKey="WixCA"
            DllEntry="WixQuietExec"
            Execute="immediate"
            Return="check" />
        <CustomAction
            Id="SetValidatePlayitdServiceStoppedCommand"
            Property="WixQuietExecCmdLine"
            Value="&quot;[SystemFolder]cmd.exe&quot; /c sc query playitd | find /I &quot;RUNNING&quot; &gt;nul &amp;&amp; exit 1 || exit 0"
            Execute="immediate" />
        <CustomAction
            Id="ValidatePlayitdServiceStopped"
            BinaryKey="WixCA"
            DllEntry="WixQuietExec"
            Execute="immediate"
            Return="check" />
        <CustomAction
            Id="SetValidatePlayitTrayClosedCommand"
            Property="WixQuietExecCmdLine"
            Value="&quot;[SystemFolder]cmd.exe&quot; /c tasklist /FI &quot;IMAGENAME eq playitd-tray.exe&quot; | find /I &quot;playitd-tray.exe&quot; &gt;nul &amp;&amp; exit 1 || exit 0"
            Execute="immediate" />
        <CustomAction
            Id="ValidatePlayitTrayClosed"
            BinaryKey="WixCA"
            DllEntry="WixQuietExec"
            Execute="immediate"
            Return="check" />
        <CustomAction
            Id="SetStartPlayitdServiceCommand"
            Property="WixQuietExecCmdLine"
            Value="&quot;[SystemFolder]cmd.exe&quot; /c net start playitd"
            Execute="immediate" />
        <CustomAction
            Id="StartPlayitdService"
            BinaryKey="WixCA"
            DllEntry="WixQuietExec"
            Execute="immediate"
            Return="ignore" />
        <CustomAction
            Id="EnsureTrayStartupShortcut"
            FileKey="exe2"
            ExeCommand="--ensure-startup-shortcut"
            Impersonate="yes"
            Return="ignore" />
        <CustomAction
            Id="RemoveTrayStartupShortcut"
            FileKey="exe2"
            ExeCommand="--remove-startup-shortcut"
            Impersonate="yes"
            Return="ignore" />

        <InstallExecuteSequence>
            <Custom Action="DetectRunningPlayit" Before="WixCloseApplications">UILevel &lt; 5</Custom>
            <Custom Action="SetPlayitCloseApprovedSilently" After="DetectRunningPlayit">UILevel &lt; 5 AND (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)</Custom>
            <Custom Action="SetStopPlayitdServiceCommand" After="WixCloseApplications">PLAYITD_CLOSE_APPROVED AND PLAYITD_SERVICE_RUNNING</Custom>
            <Custom Action="StopPlayitdService" After="SetStopPlayitdServiceCommand">PLAYITD_CLOSE_APPROVED AND PLAYITD_SERVICE_RUNNING</Custom>
            <Custom Action="SetValidatePlayitdServiceStoppedCommand" After="StopPlayitdService">PLAYITD_CLOSE_APPROVED AND PLAYITD_SERVICE_RUNNING</Custom>
            <Custom Action="ValidatePlayitdServiceStopped" After="SetValidatePlayitdServiceStoppedCommand">PLAYITD_CLOSE_APPROVED AND PLAYITD_SERVICE_RUNNING</Custom>
            <Custom Action="SetValidatePlayitTrayClosedCommand" After="ValidatePlayitdServiceStopped">PLAYITD_CLOSE_APPROVED AND PLAYITD_TRAY_RUNNING</Custom>
            <Custom Action="ValidatePlayitTrayClosed" After="SetValidatePlayitTrayClosedCommand">PLAYITD_CLOSE_APPROVED AND PLAYITD_TRAY_RUNNING</Custom>
            <Custom Action="RemoveTrayStartupShortcut" Before="RemoveFiles">REMOVE="ALL"</Custom>
            <Custom Action="EnsureTrayStartupShortcut" After="InstallFinalize">NOT REMOVE="ALL"</Custom>
            <Custom Action="SetStartPlayitdServiceCommand" After="InstallFinalize">PLAYITD_SERVICE_RUNNING AND NOT REMOVE="ALL"</Custom>
            <Custom Action="StartPlayitdService" After="SetStartPlayitdServiceCommand">PLAYITD_SERVICE_RUNNING AND NOT REMOVE="ALL"</Custom>
            <Custom Action="LaunchTrayApplication" After="InstallFinalize">NOT Installed AND UILevel &gt;= 5</Custom>
        </InstallExecuteSequence>

        <!--
          Uncomment the following `Icon` and `Property` tags to change the product icon.

          The product icon is the graphic that appears in the Add/Remove
          Programs control panel for the application.
        -->
        <Icon Id="ProductICO" SourceFile="packages\playit-cli\wix\Product.ico"/>
        <Property Id="ARPPRODUCTICON" Value="ProductICO" />

        <!--
          Adding a URL to Add/Remove Programs control panel listing for the
          application is a two step process:

          1. Uncomment the following `Property` tag with the "ARPHELPLINK" Id
             attribute value.
          2. Change the value for `Value` attribute of the following
             `Property` tag to a valid URL.
        -->
        <!--<Property Id="ARPHELPLINK" Value="ChangeMe"/>-->

        <UI Id="PlayitUI_FeatureTree">
            <TextStyle Id="WixUI_Font_Normal" FaceName="Tahoma" Size="8" />
            <TextStyle Id="WixUI_Font_Bigger" FaceName="Tahoma" Size="12" />
            <TextStyle Id="WixUI_Font_Title" FaceName="Tahoma" Size="9" Bold="yes" />

            <Property Id="DefaultUIFont" Value="WixUI_Font_Normal" />
            <Property Id="WixUI_Mode" Value="FeatureTree" />

            <DialogRef Id="ErrorDlg" />
            <DialogRef Id="FatalError" />
            <DialogRef Id="FilesInUse" />
            <DialogRef Id="MsiRMFilesInUse" />
            <DialogRef Id="PrepareDlg" />
            <DialogRef Id="ProgressDlg" />
            <DialogRef Id="ResumeDlg" />
            <DialogRef Id="UserExit" />
            <DialogRef Id="WelcomeDlg" />
            <DialogRef Id="CustomizeDlg" />
            <DialogRef Id="MaintenanceWelcomeDlg" />
            <DialogRef Id="MaintenanceTypeDlg" />

            <Publish Dialog="ExitDialog" Control="Finish" Event="EndDialog" Value="Return" Order="999">1</Publish>

            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="CustomizeDlg">NOT Installed</Publish>
            <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="PlayitVerifyReadyDlg">Installed AND PATCH</Publish>

            <Publish Dialog="CustomizeDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="1">Installed</Publish>
            <Publish Dialog="CustomizeDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2">NOT Installed</Publish>
            <Publish Dialog="CustomizeDlg" Control="Next" Event="NewDialog" Value="PlayitVerifyReadyDlg">1</Publish>

            <Publish Dialog="PlayitVerifyReadyDlg" Control="Back" Event="NewDialog" Value="CustomizeDlg" Order="1">NOT Installed OR WixUI_InstallMode = "Change"</Publish>
            <Publish Dialog="PlayitVerifyReadyDlg" Control="Back" Event="NewDialog" Value="MaintenanceTypeDlg" Order="2">Installed AND NOT PATCH</Publish>
            <Publish Dialog="PlayitVerifyReadyDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="3">Installed AND PATCH</Publish>

            <Publish Dialog="MaintenanceWelcomeDlg" Control="Next" Event="NewDialog" Value="MaintenanceTypeDlg">1</Publish>

            <Publish Dialog="MaintenanceTypeDlg" Control="ChangeButton" Event="NewDialog" Value="CustomizeDlg">1</Publish>
            <Publish Dialog="MaintenanceTypeDlg" Control="RepairButton" Event="NewDialog" Value="PlayitVerifyReadyDlg">1</Publish>
            <Publish Dialog="MaintenanceTypeDlg" Control="RemoveButton" Event="NewDialog" Value="PlayitVerifyReadyDlg">1</Publish>
            <Publish Dialog="MaintenanceTypeDlg" Control="Back" Event="NewDialog" Value="MaintenanceWelcomeDlg">1</Publish>

            <Dialog Id="PlayitVerifyReadyDlg" Width="370" Height="270" Title="!(loc.VerifyReadyDlg_Title)" TrackDiskSpace="yes">
                <Control Id="Install" Type="PushButton" ElevationShield="yes" X="212" Y="243" Width="80" Height="17" Default="yes" Hidden="yes" Disabled="yes" Text="!(loc.VerifyReadyDlgInstall)">
                    <Condition Action="show">NOT Installed AND ALLUSERS</Condition>
                    <Condition Action="enable">NOT Installed</Condition>
                    <Condition Action="default">NOT Installed</Condition>
                    <Publish Event="DoAction" Value="DetectRunningPlayit" Order="1">1</Publish>
                    <Publish Event="NewDialog" Value="PlayitCloseRunningDlg" Order="2">NOT PLAYITD_CLOSE_APPROVED AND (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)</Publish>
                    <Publish Event="EndDialog" Value="Return" Order="3"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace <> 1]]></Publish>
                    <Publish Event="SpawnDialog" Value="OutOfRbDiskDlg" Order="4"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND (PROMPTROLLBACKCOST="P" OR NOT PROMPTROLLBACKCOST)]]></Publish>
                    <Publish Event="EndDialog" Value="Return" Order="5"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND PROMPTROLLBACKCOST="D"]]></Publish>
                    <Publish Event="EnableRollback" Value="False" Order="6"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND PROMPTROLLBACKCOST="D"]]></Publish>
                    <Publish Event="SpawnDialog" Value="OutOfDiskDlg" Order="7"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND ((OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 1) OR (OutOfDiskSpace = 1 AND PROMPTROLLBACKCOST="F"))]]></Publish>
                </Control>
                <Control Id="InstallNoShield" Type="PushButton" ElevationShield="no" X="212" Y="243" Width="80" Height="17" Default="yes" Hidden="yes" Disabled="yes" Text="!(loc.VerifyReadyDlgInstall)">
                    <Condition Action="show">NOT Installed AND NOT ALLUSERS</Condition>
                    <Condition Action="enable">NOT Installed</Condition>
                    <Condition Action="default">NOT Installed</Condition>
                    <Publish Event="DoAction" Value="DetectRunningPlayit" Order="1">1</Publish>
                    <Publish Event="NewDialog" Value="PlayitCloseRunningDlg" Order="2">NOT PLAYITD_CLOSE_APPROVED AND (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)</Publish>
                    <Publish Event="EndDialog" Value="Return" Order="3"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace <> 1]]></Publish>
                    <Publish Event="SpawnDialog" Value="OutOfRbDiskDlg" Order="4"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND (PROMPTROLLBACKCOST="P" OR NOT PROMPTROLLBACKCOST)]]></Publish>
                    <Publish Event="EndDialog" Value="Return" Order="5"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND PROMPTROLLBACKCOST="D"]]></Publish>
                    <Publish Event="EnableRollback" Value="False" Order="6"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND PROMPTROLLBACKCOST="D"]]></Publish>
                    <Publish Event="SpawnDialog" Value="OutOfDiskDlg" Order="7"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND ((OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 1) OR (OutOfDiskSpace = 1 AND PROMPTROLLBACKCOST="F"))]]></Publish>
                </Control>
                <Control Id="Change" Type="PushButton" ElevationShield="yes" X="212" Y="243" Width="80" Height="17" Default="yes" Hidden="yes" Disabled="yes" Text="!(loc.VerifyReadyDlgChange)">
                    <Condition Action="show">WixUI_InstallMode = "Change" AND ALLUSERS AND (ADDLOCAL OR REMOVE)</Condition>
                    <Condition Action="enable">WixUI_InstallMode = "Change"</Condition>
                    <Condition Action="default">WixUI_InstallMode = "Change"</Condition>
                    <Publish Event="DoAction" Value="DetectRunningPlayit" Order="1">1</Publish>
                    <Publish Event="NewDialog" Value="PlayitCloseRunningDlg" Order="2">NOT PLAYITD_CLOSE_APPROVED AND (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)</Publish>
                    <Publish Event="EndDialog" Value="Return" Order="3"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace <> 1]]></Publish>
                    <Publish Event="SpawnDialog" Value="OutOfRbDiskDlg" Order="4"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND (PROMPTROLLBACKCOST="P" OR NOT PROMPTROLLBACKCOST)]]></Publish>
                    <Publish Event="EndDialog" Value="Return" Order="5"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND PROMPTROLLBACKCOST="D"]]></Publish>
                    <Publish Event="EnableRollback" Value="False" Order="6"><![CDATA[(PLAYITD_CLOSE_APPROVED OR NOT (PLAYITD_SERVICE_RUNNING OR PLAYITD_TRAY_RUNNING)) AND OutOfDiskSpace = 1 AND OutOfNoRbDiskSpace = 0 AND PROMPTROLLBACKCOST="D"]]></Publish>
